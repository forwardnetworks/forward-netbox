/**
 * @intent Forward ACI Application Profiles
 * @description Conservative ACI application-profile map; emits no rows until Forward exposes app-profile identity.
 */

@query
f(forward_netbox_shard_keys: List<String>) =
foreach device in network.devices
where false
where isEmpty(forward_netbox_shard_keys) || device.name in forward_netbox_shard_keys
select distinct {
  fabric_name: "",
  tenant_name: "",
  name: "",
  description: ""
};
