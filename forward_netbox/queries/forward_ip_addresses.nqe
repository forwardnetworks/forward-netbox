routed_vlan_ipv6 =
  foreach device in network.devices
  where device.snapshotInfo.result == DeviceSnapshotResult.completed
  where device.platform.vendor != Vendor.FORWARD_CUSTOM
  foreach interface in device.interfaces
  where isPresent(interface.routedVlan?.ipv6?.addresses)
  foreach address in interface.routedVlan.ipv6.addresses
  where address.prefixLength >= 127 || address.ip != networkAddress(ipSubnet(address.ip, address.prefixLength))
  select {
    device: device.name,
    interface: interface.name,
    vrf: if isPresent(interface.routedVlan.networkInstanceName)
      then if interface.routedVlan.networkInstanceName != "default" then interface.routedVlan.networkInstanceName else null : String
      else null : String,
    address: ipSubnet(address.ip, address.prefixLength),
    host_ip: address.ip,
    prefix_length: address.prefixLength,
    status: "active"
  };

candidate_rows =
  foreach row in (
  subinterface_ipv4 + subinterface_ipv6 + bridge_ipv4 + bridge_ipv6 + tunnel_ipv4 + tunnel_ipv6
    + routed_vlan_ipv4 + routed_vlan_ipv6
)
  select distinct row;

global_candidate_rows =
  foreach row in candidate_rows
  where !isPresent(row.vrf)
  select row;

global_rows =
  foreach row in global_candidate_rows
  group row as grouped_rows by row.host_ip as host_ip
  let chosen_prefix_length = max(foreach candidate in grouped_rows
    select candidate.prefix_length)
  let chosen_device = min(foreach candidate in grouped_rows
    where candidate.prefix_length == chosen_prefix_length
    select candidate.device)
  let chosen_interface = min(foreach candidate in grouped_rows
    where candidate.prefix_length == chosen_prefix_length
    select candidate.interface)
  select {
    device: chosen_device,
    interface: chosen_interface,
    vrf: null : String,
    address: ipSubnet(host_ip, chosen_prefix_length),
    status: "active"
  };

vrf_candidate_rows =
  foreach row in candidate_rows
  where isPresent(row.vrf)
  select row;

vrf_rows =
  foreach row in vrf_candidate_rows
  group row as grouped_rows by {address: row.address, vrf: row.vrf} as key
  let chosen_device = min(foreach candidate in grouped_rows
    select candidate.device)
  let chosen_interface = min(foreach candidate in grouped_rows
    where candidate.device == chosen_device
    select candidate.interface)
  select {
    device: chosen_device,
    interface: chosen_interface,
    vrf: key.vrf,
    address: key.address,
    status: "active"
  };

@primaryKey(address, vrf)
foreach row in (global_rows + vrf_rows)
select distinct row
