  foreach address in interface.bridge.ipv4.addresses
  where address.prefixLength >= 31 || address.ip != networkAddress(ipSubnet(address.ip, address.prefixLength))
  where address.prefixLength >= 31 || address.ip != broadcastAddress(ipSubnet(address.ip, address.prefixLength))
