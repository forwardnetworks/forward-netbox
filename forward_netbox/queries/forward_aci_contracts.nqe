/**
 * @intent Forward ACI Contracts
 * @description Conservative ACI contract map; emits no rows until zoning-rule parsing is bounded.
 */

@query
f(forward_netbox_shard_keys: List<String>) =
foreach device in network.devices
where false
where isEmpty(forward_netbox_shard_keys) || device.name in forward_netbox_shard_keys
select distinct {
  fabric_name: "",
  tenant_name: "",
  name: "",
  scope: "context",
  qos_class: "",
  target_dscp: "",
  description: ""
};
