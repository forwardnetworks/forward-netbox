  foreach address in interface.bridge.ipv4.addresses
  let assigned_address = ipSubnet(address.ip, address.prefixLength)
  where address.prefixLength < 31
  where address.ip == broadcastAddress(assigned_address)
  select {
    reason: "ipv4-broadcast-address",
    device: device.name,
    interface: interface.name,
    address: assigned_address
  };

