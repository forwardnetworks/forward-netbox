    interface: interface.name,
    address: assigned_address
  };

foreach row in (
  subinterface_ipv4_network_ids + subinterface_ipv4_broadcasts + subinterface_ipv6_network_ids
    + bridge_ipv4_network_ids + bridge_ipv4_broadcasts + bridge_ipv6_network_ids
    + tunnel_ipv4_network_ids + tunnel_ipv4_broadcasts + tunnel_ipv6_network_ids
    + routed_vlan_ipv4_network_ids + routed_vlan_ipv4_broadcasts + routed_vlan_ipv6_network_ids
)
select distinct row
